   <Row>
    <Cell><Data ss:Type="String">NCT04598347</Data></Cell>
    <Cell><Data ss:Type="String">Evaluation of the Possible Vertical Transmission of SARS-CoV-2 Through Study of Amniotic Fluid and Chorionic Villi of Affected Pregnant Women for the COVID-19</Data></Cell>
