   <Row>
    <Cell><Data ss:Type="String">NCT04632355</Data></Cell>
    <Cell><Data ss:Type="String">Musculoskeletal Pain in Patients With Covid-19 Who Have Hospital Care</Data></Cell>
    <Cell><Data ss:Type="String">UNKNOWN</Data></Cell>
