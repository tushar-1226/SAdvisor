   </Row>
   <Row>
    <Cell><Data ss:Type="String">NCT04864548</Data></Cell>
    <Cell><Data ss:Type="String">COV-CHIM01: SARS-CoV-2 (COVID-19) Dose Finding Infection Study</Data></Cell>
    <Cell><Data ss:Type="String">UNKNOWN</Data></Cell>
    <Cell><Data ss:Type="String">Phase 1</Data></Cell>
